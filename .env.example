# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# ─── News API ─────────────────────────────────────────────────────────────────
# TODO: Replace with a real News API key (e.g. NewsAPI.org)
NEWS_API_KEY=mock_news_api_key
NEWS_API_URL=https://newsapi.org/v2/everything

# ─── AIS / Vessel Data ────────────────────────────────────────────────────────
# TODO: Replace with a real AIS provider key (e.g. MarineTraffic, VesselFinder)
AIS_API_KEY=mock_ais_api_key
AIS_API_URL=https://services.marinetraffic.com/api

# ─── Port Data ────────────────────────────────────────────────────────────────
# TODO: Replace with your internal port-operations database URL
PORT_DB_URL=sqlite:///./maritime.db

# ─── Weather API ─────────────────────────────────────────────────────────────
# TODO: Replace with a real weather provider key (e.g. OpenWeatherMap, StormGlass)
WEATHER_API_KEY=mock_weather_api_key
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# ─── Email (optional) ────────────────────────────────────────────────────────
# TODO: Configure SMTP settings for report delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=secret
EMAIL_FROM=reports@maritime-agents.local
EMAIL_TO=ops-team@example.com

# ─── Report Storage ──────────────────────────────────────────────────────────
REPORTS_DIR=./reports
